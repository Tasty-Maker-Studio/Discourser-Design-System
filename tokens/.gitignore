# Export to Figma — generated by pnpm figma:export, not committed
export-to-figma/*
!export-to-figma/.gitkeep

# Imported from Figma — generated by pnpm organize-tokens, not committed
imported-from-figma/*
!imported-from-figma/.gitkeep

# Keep reference files
!primitives/colors.json
!semantic/colors.light.json
!semantic/colors.dark.json

# Generated JSON files at root — produced by pnpm organize-tokens
primitives-generated.json
semantic-light-generated.json
semantic-dark-generated.json

# Archive backups — created by pnpm organize-tokens, local only
.archive/

# Keep documentation
!README.md
