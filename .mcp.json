{
  "mcpServers": {
    "figma-desktop": {
      "type": "http",
      "url": "http://127.0.0.1:3845/mcp"
    },
    "figma-remote": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    },
    "panda": {
      "command": "npx",
      "args": ["panda", "mcp"]
    },
    "ark-ui": {
      "command": "npx",
      "args": ["@ark-ui/mcp"]
    }
  }
}
